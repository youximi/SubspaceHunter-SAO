# Normalize text files.
* text=auto

# Unity YAML assets should remain text unless explicitly routed to LFS below.
*.cs text diff=csharp
*.shader text
*.cginc text
*.hlsl text
*.compute text
*.asmdef text
*.json text
*.xml text
*.txt text
*.md text

# Large Unity project files in this repo exceed GitHub's warning threshold.
# Use LFS for Unity serialized assets/scenes to avoid 50 MiB warnings and 100 MiB hard failures.
Assets/**/*.unity filter=lfs diff=lfs merge=lfs -text
Assets/**/*.asset filter=lfs diff=lfs merge=lfs -text
Assets/**/*.prefab filter=lfs diff=lfs merge=lfs -text

